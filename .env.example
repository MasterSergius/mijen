# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=mijen
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mijen

# SQLAlchemy connection string — hostname must match the compose service name
DATABASE_URL=postgresql://mijen:changeme@db:5432/mijen

# ── Security ──────────────────────────────────────────────────────────────────

# Webhook secret — pass as X-Webhook-Secret header when triggering tasks via POST
# Leave empty to disable webhook authentication (not recommended in production)
WEBHOOK_SECRET=change-this-to-a-long-random-string

# HTTP Basic Auth for the web UI — leave both empty to disable
MIJEN_AUTH_USER=admin
MIJEN_AUTH_PASS=changeme

# ── Application ───────────────────────────────────────────────────────────────

# Public base URL shown in the webhook info dialog
MIJEN_PUBLIC_URL=http://localhost:8080

# ── Local projects ────────────────────────────────────────────────────────────

# Host directory to expose as local projects inside the container.
# Set this to the parent folder containing your local projects.
# Inside the container it will be mounted at /mnt/projects.
# Leave empty to use a harmless placeholder (no local projects accessible).
# Example: LOCAL_PROJECTS_DIR=/home/yourname/projects
LOCAL_PROJECTS_DIR=
